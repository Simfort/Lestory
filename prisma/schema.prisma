// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User{
  id String @id @default(cuid())
  email String @unique
  username String
  password String?
  image String? 
  views StoryView[] @relation(name: "ViewToUser")
  likes StoryLike[] @relation(name: "LikeToUser")
  comment Comment[] @relation(name: "CommentToUser")
  stories Story[] @relation(name: "ManyStoryToManyUser")
  @@map("users")
}
model Story{
  id Int @id @default(autoincrement())
  title String
  description String
  private Boolean
  category String
  type String
  content String?
  chapters Chapter[] @relation(name: "ChapterToStory")
  keywords String
  cover String @default("")
  likes StoryLike[] @relation(name: "LikeToStory")
  views StoryView[] @relation(name: "ViewToStory")
  author User @relation(name: "ManyStoryToManyUser",fields: [author_email],references: [email])
  author_email String
  createdAt DateTime @default(now())
  @@map("stories")
}

model Chapter{
  id Int @id @default(autoincrement())
  title String
  description String?
  story Story @relation(name: "ChapterToStory",fields: [storyId],references: [id])
  images String[]
  storyId Int
  createdAt DateTime @default(now())
  @@map("chapters")
}

model StoryView {
  id        Int      @id @default(autoincrement())
  storyId   Int
  
  ip        String   // для анонимных пользователей
  viewedAt  DateTime @default(now())
  userAgent String?
  story Story @relation(name: "ViewToStory",fields: [storyId], references: [id])
  user User? @relation(name: "ViewToUser",fields: [userId],references: [id])
  userId    String?  // если есть авторизация
  @@unique([storyId,ip])
}
model StoryLike{
  id        Int      @id @default(autoincrement())
  storyId Int

  ip String 
  viewedAt DateTime @default(now())
  userAgent String? 
  story Story @relation(name: "LikeToStory",fields: [storyId], references: [id])
  user User? @relation(name: "LikeToUser",fields: [userId],references: [id])
  userId    String?
  @@unique([storyId,ip])
}

model Comment{
  id Int @id @default(autoincrement())
  storyId Int
  author User @relation(name: "CommentToUser",fields: [authorId],references: [id])
  authorId String
  comment_id Int?    
  comment  Comment? @relation(name: "AnswerToComment", fields: [comment_id], references: [id])
  answers  Comment[] @relation(name: "AnswerToComment")
  content String
  createdAt DateTime @default(now())
  likes CommentLike[] @relation(name: "LikesToComment")
}
model CommentLike{
  id Int @id @default(autoincrement())
  userId String
  comment_id Int?    
  comment  Comment? @relation(name: "LikesToComment", fields: [comment_id], references: [id])  
  createdAt DateTime @default(now())
}