// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User{
  id String @id @default(cuid())
  email String @unique
  username String
  password String?
  image String? 
  stories Story[] @relation(name: "ManyStoryToManyUser")
  @@map("users")
}
model Story{
  id Int @id @default(autoincrement())
  title String
  description String
  private Boolean
  category String
  type String
  content String?
  chapters Chapter[] @relation(name: "ChapterToStory")
  keywords String
  cover String @default("")
  likes StoryLike[] @relation(name: "LikeToStory")
  views StoryView[] @relation(name: "ViewToStory")
  author User[] @relation(name: "ManyStoryToManyUser")
  createdAt DateTime @default(now())
  @@map("stories")
}

model Chapter{
  id Int @id @default(autoincrement())
  title String
  description String?
  story Story @relation(name: "ChapterToStory",fields: [storyId],references: [id])
  images String[]
  storyId Int
  createdAt DateTime @default(now())
  @@map("chapters")
}

model StoryView {
  id        Int      @id @default(autoincrement())
  storyId   Int
  userId    String?  // если есть авторизация
  ip        String   // для анонимных пользователей
  viewedAt  DateTime @default(now())
  userAgent String?
  story Story @relation(name: "ViewToStory",fields: [storyId], references: [id])

  @@unique([storyId,ip])
}
model StoryLike{
  id        Int      @id @default(autoincrement())
  storyId Int
  userId String?
  ip String 
  viewedAt DateTime @default(now())
  userAgent String? 
  story Story @relation(name: "LikeToStory",fields: [storyId], references: [id])

  @@unique([storyId,ip])
}